# 老项目使用 Node 12（package.json 里多个 dep 是 2018 年的版本）
# M4 是 arm64，Node 12 没有原生包，强制用 linux/amd64 通过 Rosetta 跑
FROM --platform=linux/amd64 node:12.22.12-bullseye-slim

# node-gyp 需要 python2 和 build 工具
# chromium 给 puppeteer-core 用（生成简历 PDF）
# fonts-noto-cjk 用于中文字符渲染
RUN apt-get update && apt-get install -y --no-install-recommends \
    python2 \
    make \
    g++ \
    ca-certificates \
    git \
    chromium \
    fonts-liberation \
    fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python2 /usr/local/bin/python

WORKDIR /app

# 先只拷贝 package.json，用 docker 缓存层加速重建
COPY package.json ./

# puppeteer-core 不下载内置 chromium，用 apt 装的那个
ENV NPM_CONFIG_LOGLEVEL=warn \
    SASS_BINARY_SITE=https://npmmirror.com/mirrors/node-sass \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium \
    PUPPETEER_SKIP_DOWNLOAD=true

# 用 npmmirror 加速国内下载
RUN npm config set registry https://registry.npmmirror.com \
    && npm install --unsafe-perm --no-audit --no-fund --legacy-peer-deps || npm install --unsafe-perm --no-audit --no-fund

# 源码后续通过 volume 挂载进来
EXPOSE 4000

CMD ["npm", "run", "start-dev"]
