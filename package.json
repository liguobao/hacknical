{
  "name": "hacknical",
  "version": "1.7.6",
  "description": "hacker & technical",
  "main": "dist/bin/app.js",
  "scripts": {
    "build-app": "babel app -d dist --copy-files",
    "build-static": "npm run build-dll-pro && npm run build-src",
    "build-src": "cross-env NODE_ENV=production webpack --progress --colors --config frontend/webpack/webpack.production.js -p",
    "build-dll": "cross-env NODE_ENV=localdev webpack --config frontend/webpack/webpack.dll.js --progress --colors",
    "build-dll-pro": "cross-env NODE_ENV=production webpack --config frontend/webpack/webpack.dll.js --progress --colors -p",
    "start-dev": "npm run build-dll && npm run start-app",
    "start-app": "npm run start-app:server & npm run start-app:client",
    "start-app:server": "cross-env NODE_ENV=localdev DEBUG=hacknical-local* nodemon app/index.js",
    "start-app:client": "cross-env NODE_ENV=localdev webpack --progress --colors --config frontend/webpack/webpack.dev.js --watch",
    "start": "cross-env NODE_ENV=production forever start --killSignal=SIGTERM -a -l /var/log/ecmadao/hacknical/forever_log -e /var/log/ecmadao/hacknical/error_log dist/bin/app.js",
    "stop": "cross-env NODE_ENV=production forever stop dist/bin/app.js",
    "precommit": "npm run lint",
    "lint": "./node_modules/.bin/eslint frontend/* && ./node_modules/.bin/eslint app/*",
    "deploy": "git checkout master && git pull origin master && npm i && npm i --only=dev && bash ./scripts/deploy.sh"
  },
  "author": "ecmadao",
  "license": "Apache-2.0",
  "devDependencies": {
