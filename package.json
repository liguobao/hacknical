{
  "name": "hacknical",
  "version": "1.7.6",
  "description": "hacker & technical",
  "main": "dist/bin/app.js",
  "scripts": {
    "build-app": "babel app -d dist --copy-files",
    "build-static": "npm run build-src",
    "build-src": "cross-env NODE_ENV=production webpack --config frontend/webpack/webpack.production.js --progress --color",
    "build-dll": "node -e \"console.log('DLL build removed in webpack 5 migration; use npm run build-src instead.')\"",
    "build-dll-pro": "npm run build-dll",
    "start-dev": "npm run start-app",
    "start-app": "npm run start-app:server & npm run start-app:client",
    "start-app:server": "cross-env NODE_ENV=localdev DEBUG=hacknical-local* nodemon app/index.js",
    "start-app:client": "cross-env NODE_ENV=localdev webpack --config frontend/webpack/webpack.dev.js --watch --progress --color",
    "start": "cross-env NODE_ENV=production pm2 startOrRestart ecosystem.config.js --update-env",
    "stop": "cross-env NODE_ENV=production pm2 delete hacknical || true",
    "lint": "./node_modules/.bin/eslint frontend app",
    "postinstall": "patch-package",
    "deploy": "git checkout master && git pull origin master && npm i && npm i --only=dev && bash ./scripts/deploy.sh",
    "prepare": "husky"
  },
  "author": "ecmadao",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.24.0",
    "@babel/plugin-transform-private-methods": "^7.24.0",
    "@babel/plugin-transform-private-property-in-object": "^7.24.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@sentry/browser": "^10.49.0",
    "ajv": "^8.18.0",
    "babel-loader": "^10.1.1",
    "cal-heatmap": "^4.2.4",
    "chart.js": "^4.5.1",
    "classnames": "^2.2.5",
    "clipboard": "^2.0.11",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "deepcopy": "^2.1.0",
    "es6-promise": "^4.2.8",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-import": "^2.32.0",
